# Пример конфигурации aioips. Скопируйте в `.env` и заполните своими значениями.
# Файл `.env` добавлен в .gitignore и НИКОГДА не должен попадать в репозиторий.
#
# Правило именования: префикс IPS_ + имя параметра в верхнем регистре.

# --- Подключение (обязательно) ---
IPS_BASE_URL=http://your-ips-host:8080

# --- Авторизация: вариант 1 — логин/пароль (рекомендуется) ---
IPS_LOGIN_NAME=YOUR_LOGIN
IPS_PASSWORD=YOUR_PASSWORD
# Имя роли (резолвится в идентификатор автоматически) ИЛИ числовой идентификатор роли:
IPS_ROLE_NAME=Администратор
# IPS_ROLE_ID=10
# Уровень доступа (0 — обычный):
IPS_ACCESS_LEVEL_ID=0

# --- Авторизация: вариант 2 — заранее полученный access-токен (вместо логина/пароля) ---
# IPS_ACCESS_TOKEN=eyJ...

# --- Сетевые параметры (опционально) ---
IPS_REQUEST_TIMEOUT=30
IPS_MAX_RETRIES=3
IPS_VERIFY_SSL=true

# --- Логирование (опционально) ---
IPS_LOG_LEVEL=ERROR
IPS_LOG_JSON=false
